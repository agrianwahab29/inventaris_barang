        "test:debug": "npx playwright test --debug",
        "test:report": "npx playwright show-report",
        "e2e": "npx playwright test",
        "e2e:headed": "npx playwright test --headed"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
